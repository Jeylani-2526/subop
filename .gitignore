# =============================================================================
# SUBOP .gitignore
# =============================================================================

# --- Environment ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.log

# --- Node / React (BI Dashboard — M9+) ---
node_modules/
/services/bi-dashboard/frontend/build/
/services/bi-dashboard/frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# --- Data files (too large for git — use object storage or Git LFS) ---
data/samples/*.csv
data/samples/*.xlsx
data/samples/*.parquet
data/samples/*.json
data/samples/*.sql

# Keep placeholder files
!data/samples/.gitkeep

# --- ML / Model artifacts (data-quality anomaly model — M10+) ---
services/data-quality/models/*.pkl
services/data-quality/models/*.pt
services/data-quality/models/*.h5
!services/data-quality/models/.gitkeep

# --- Architecture diagrams (binary — use docs/architecture/) ---
# Keep .drawio XML (text-based, version-control friendly)
# Keep .png exports
# Ignore large binary exports
docs/architecture/*.pdf

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker ---
.docker/
