# =============================================================================
# SUBOP — Environment Variables Template
# Copy this file to .env and fill in your local values.
# NEVER commit .env to git — it is in .gitignore.
# =============================================================================

# --- PostgreSQL (primary data warehouse + platform metadata) ---
POSTGRES_DB=subop
POSTGRES_USER=subop
POSTGRES_PASSWORD=subop_dev          # Change for any shared environment

# --- pgAdmin (database admin UI — http://localhost:5050) ---
PGADMIN_EMAIL=admin@subop.local
PGADMIN_PASSWORD=admin_dev           # Change for any shared environment

# --- FastAPI backend (activated in M3) ---
API_SECRET_KEY=dev-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true                       # Set to false in production / pilot

# --- Kafka (CDC and streaming ingestion) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CDC_EVENTS=subop-cdc-events
KAFKA_TOPIC_STREAM_INGEST=subop-stream-ingest

# --- Debezium CDC connector (activated in M7) ---
DEBEZIUM_CONNECTOR_NAME=subop-postgres-cdc
DEBEZIUM_DATABASE_HOSTNAME=postgres
DEBEZIUM_DATABASE_PORT=5432
DEBEZIUM_DATABASE_USER=${POSTGRES_USER}
DEBEZIUM_DATABASE_PASSWORD=${POSTGRES_PASSWORD}
DEBEZIUM_DATABASE_DBNAME=${POSTGRES_DB}

# --- ETL Engine (activated in M5) ---
ETL_BATCH_SIZE=10000
ETL_MAX_WORKERS=4
ETL_LOG_LEVEL=INFO

# --- Data Quality Engine (activated in M10) ---
QUALITY_ALERT_EMAIL=team@subop.local
QUALITY_MIN_SCORE_THRESHOLD=0.80    # Alert when dataset score drops below this

# --- Security (activated in M11) ---
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
